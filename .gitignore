# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment variables (never commit secrets) ──────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/
out/

# ── Vitest ────────────────────────────────────────────────────────────────────
.vitest-cache/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore local override files
docker-compose.override.yml
docker-compose.local.yml

# ── Redis data (if running Redis locally outside Docker) ──────────────────────
dump.rdb
appendonly.aof

# ── Misc ──────────────────────────────────────────────────────────────────────
.cache/
.temp/
tmp/
